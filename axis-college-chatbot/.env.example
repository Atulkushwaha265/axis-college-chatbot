# Axis Colleges AI Chatbot - Environment Variables
# Copy this file to .env and update with your actual values

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-here-change-in-production

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=axis_college_ai
DB_USER=postgres
DB_PASSWORD=your-database-password-here
DATABASE_URL=postgresql://postgres:your-database-password-here@localhost:5432/axis_college_ai

# OpenAI Configuration (Optional - for AI responses)
OPENAI_API_KEY=your-openai-api-key-here

# Email Configuration (Optional - for notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Redis Configuration (Optional - for caching and sessions)
REDIS_URL=redis://localhost:6379

# Security Configuration
SESSION_TIMEOUT=3600
CSRF_SECRET_KEY=your-csrf-secret-key-here

# Rate Limiting
RATELIMIT_ENABLED=true
RATELIMIT_DEFAULT=100 per hour

# Logging Configuration
LOG_LEVEL=INFO
LOG_TO_STDOUT=false

# File Upload Configuration
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@axiscolleges.edu.in

# Development/Production
ENVIRONMENT=development
DEBUG=true

# CORS Configuration (if needed)
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# API Configuration
API_VERSION=v1
API_PREFIX=/api

# Monitoring and Analytics
SENTRY_DSN=your-sentry-dsn-here
GOOGLE_ANALYTICS_ID=your-ga-id-here

# Social Media Integration (Optional)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret

# SMS Integration (Optional)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Payment Gateway (Optional)
STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_SECRET_KEY=your-stripe-secret-key

# Cloud Storage (Optional)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=us-east-1

# Google Services (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Maps Integration (Optional)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Weather API (Optional)
OPENWEATHER_API_KEY=your-openweather-api-key

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Cache Configuration
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300

# Session Configuration
SESSION_TYPE=filesystem
SESSION_PERMANENT=false
SESSION_USE_SIGNER=true
SESSION_KEY_PREFIX=axis_chatbot:

# Security Headers
FORCE_HTTPS=false
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

# Database Pool Configuration
SQLALCHEMY_ENGINE_OPTIONS=pool_size=10,pool_recycle=3600,pool_pre_ping=true

# Application Settings
APP_NAME=Axis Colleges AI Chatbot
APP_VERSION=1.0.0
APP_DESCRIPTION=AI-powered chatbot for Axis Colleges, Kanpur
APP_URL=http://localhost:5000

# College Information
COLLEGE_NAME=Axis Colleges
COLLEGE_ADDRESS=Kanpur-Lucknow Highway, Kanpur, Uttar Pradesh - 209305
COLLEGE_PHONE=0512-2580001
COLLEGE_EMAIL=info@axiscolleges.edu.in

# Chatbot Configuration
BOT_NAME=Axis AI Assistant
BOT_AVATAR=🤖
BOT_WELCOME_MESSAGE=Welcome to Axis Colleges AI Assistant! How can I help you today?
BOT_FALLBACK_MESSAGE=I'm sorry, I don't understand. Could you please rephrase your question?

# Performance Monitoring
ENABLE_PROFILING=false
PROFILING_INTERVAL=60

# Error Reporting
ERROR_EMAIL_RECIPIENTS=admin@axiscolleges.edu.in
ERROR_EMAIL_SUBJECT=Axis Chatbot Error Report

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System is under maintenance. Please try again later.

# Feature Flags
ENABLE_OPENAI_INTEGRATION=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_ANALYTICS=false
ENABLE_BACKUP=true

# Development Settings
RELOAD=true
DEBUG_TB_ENABLED=false
DEBUG_TB_INTERCEPT_REDIRECTS=false

# Testing Configuration
TESTING=false
TEST_DATABASE_URL=sqlite:///:memory:

# Deployment Settings
DEPLOY_ENVIRONMENT=local
HERoku_APP_NAME=your-heroku-app-name

# Docker Configuration
DOCKER_PORT=5000
DOCKER_HOST=0.0.0.0

# SSL Configuration
SSL_DISABLE=true
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# Proxy Configuration
PROXY_FIX_ENABLED=false
PROXY_FIX_FOR=1
PROXY_FIX_PROTO=1
PROXY_FIX_HOST=1
PROXY_FIX_PORT=1
PROXY_FIX_PREFIX=1

# API Rate Limiting
API_RATE_LIMIT=100 per hour
CHAT_RATE_LIMIT=10 per minute
LOGIN_RATE_LIMIT=5 per minute

# Database Migration
FLASK_MIGRATE_ENABLED=true

# Static Files
STATIC_FOLDER=static
STATIC_URL_PATH=/static

# Templates
TEMPLATES_FOLDER=templates

# Upload Settings
ALLOWED_EXTENSIONS=txt,pdf,png,jpg,jpeg,gif
MAX_UPLOAD_SIZE=16777216

# Security
WTF_CSRF_ENABLED=true
WTF_CSRF_TIME_LIMIT=3600

# Session Security
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=false

# Logging
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Monitoring
HEALTH_CHECK_ENABLED=true
METRICS_ENABLED=false

# Cache Keys
CACHE_KEY_PREFIX=axis_chatbot:
CACHE_DEFAULT_TIMEOUT=300

# Background Tasks
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email Templates
EMAIL_TEMPLATE_FOLDER=templates/email

# API Documentation
API_DOCS_ENABLED=true
API_DOCS_URL=/docs

# CORS
CORS_ENABLED=false
CORS_ORIGINS=*

# JSON Web Tokens
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# Database
SQLALCHEMY_TRACK_MODIFICATIONS=false
SQLALCHEMY_ECHO=false
SQLALCHEMY_RECORD_QUERIES=false

# Development Server
HOST=0.0.0.0
PORT=5000

# Production
WEB_CONCURRENCY=3

# Timezone
TIMEZONE=Asia/Kolkata

# Locale
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,hi

# Date Format
DATE_FORMAT=%Y-%m-%d
TIME_FORMAT=%H:%M:%S
DATETIME_FORMAT=%Y-%m-%d %H:%M:%S

# Currency
CURRENCY=INR
CURRENCY_SYMBOL=₹

# Number Formatting
NUMBER_GROUPING=true
DECIMAL_PLACES=2

# File Paths
BASE_DIR=/path/to/axis-college-chatbot
DATA_DIR=data
LOGS_DIR=logs
UPLOADS_DIR=uploads
STATIC_DIR=static
TEMPLATES_DIR=templates
